EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
EXPO_PUBLIC_GEMINI_API_KEY=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Android OAuth client ID (type: Android) — same Firebase/Google project; package name + debug/release SHA-1
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# iOS OAuth client ID (type: iOS) — bundle ID + App Store ID as needed in Google Cloud
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# In-app Privacy / Terms (optional; defaults to example.com in privacy screen)
EXPO_PUBLIC_PRIVACY_POLICY_URL=
EXPO_PUBLIC_TERMS_URL=

# Use Firebase Callable `geminiCategorize` / `geminiInsights` (requires deploy + sign-in)
EXPO_PUBLIC_USE_GEMINI_CALLABLE=

