rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isBusinessMember(businessId) {
      return isAuth() && exists(
        /databases/$(database)/documents/businesses/$(businessId)/members/$(request.auth.uid)
      );
    }
    
    function isBookMember(bookId) {
      return isAuth() && exists(
        /databases/$(database)/documents/books/$(bookId)/members/$(request.auth.uid)
      );
    }
    
    function isBookCreator(bookId) {
      return isAuth()
        && exists(/databases/$(database)/documents/books/$(bookId))
        && get(/databases/$(database)/documents/books/$(bookId)).data.created_by == request.auth.uid;
    }
    
    function getMemberRole(bookId) {
      return get(
        /databases/$(database)/documents/books/$(bookId)/members/$(request.auth.uid)
      ).data.role;
    }
    
    /** Any member may touch `last_entry_date` when creating/updating entries; admins may change other book fields. */
    function isBookLastEntryDateOnlyUpdate(bookId) {
      return isBookMember(bookId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['last_entry_date']);
    }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    match /businesses/{businessId} {
      allow read: if isBusinessMember(businessId) || 
        resource.data.owner_id == request.auth.uid;
      allow create: if isAuth();
      allow update, delete: if resource.data.owner_id == request.auth.uid;
      
      match /members/{memberId} {
        allow read: if isBusinessMember(businessId);
        allow write: if get(/databases/$(database)/documents/businesses/$(businessId)).data.owner_id == request.auth.uid;
      }
    }
    
    match /books/{bookId} {
      allow read: if isBookMember(bookId)
        || (isAuth() && resource.data.created_by == request.auth.uid);
      allow create: if isAuth();
      allow update: if isBookMember(bookId) && (
        getMemberRole(bookId) in ['PRIMARY_ADMIN', 'ADMIN']
        || isBookLastEntryDateOnlyUpdate(bookId)
      );
      allow delete: if isBookMember(bookId) && 
        getMemberRole(bookId) == 'PRIMARY_ADMIN';
      
      match /members/{memberId} {
        allow read: if isBookMember(bookId) || isBookCreator(bookId);
        allow create: if isAuth()
          && memberId == request.auth.uid
          && isBookCreator(bookId)
          && request.resource.data.user_id == request.auth.uid
          && request.resource.data.book_id == bookId
          && request.resource.data.role == 'PRIMARY_ADMIN';
        allow update, delete: if isBookMember(bookId) &&
          getMemberRole(bookId) in ['PRIMARY_ADMIN', 'ADMIN'];
      }
      
      match /entries/{entryId} {
        allow read: if isBookMember(bookId);
        allow create: if isBookMember(bookId);
        allow update, delete: if isBookMember(bookId) && 
          (resource.data.created_by == request.auth.uid || 
          getMemberRole(bookId) in ['PRIMARY_ADMIN', 'ADMIN']);
      }
      
      match /contacts/{contactId} {
        allow read, write: if isBookMember(bookId);
      }
      
      match /categories/{categoryId} {
        allow read, write: if isBookMember(bookId);
      }
      
      match /payment_modes/{modeId} {
        allow read, write: if isBookMember(bookId);
      }
      
      match /custom_fields/{fieldId} {
        allow read, write: if isBookMember(bookId);
      }
      
      match /summaries/{summaryId} {
        allow read: if isBookMember(bookId);
        allow create, update: if isBookMember(bookId);
        allow delete: if false;
      }

      match /audit_logs/{logId} {
        allow read: if isBookMember(bookId);
        allow create: if isBookMember(bookId);
        allow update, delete: if false;
      }
    }
    
    match /audit_logs/{logId} {
      allow read: if isAuth() && resource.data.user_id == request.auth.uid;
      allow write: if false;
    }
    
    match /rate_limits/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    match /gdpr_requests/{requestId} {
      allow create: if isAuth();
      allow read: if isAuth() && resource.data.user_id == request.auth.uid;
      allow write: if false;
    }
  }
}

